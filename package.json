{
  "name": "rgd-suite",
  "displayName": "RGD Suite",
  "description": "Corsix, but for VS Code! Complete toolkit for Relic Game Data (RGD) files — table editor, Lua↔RGD conversion, SGA extraction, parity checker, and CLI commands for Dawn of War / Company of Heroes modding.",
  "version": "1.1.1",
  "publisher": "CannibalToast",
  "repository": {
    "type": "git",
    "url": "https://github.com/CannibalToast/rgd-suite"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onFileSystem:rgd",
    "workspaceContains:**/*.rgd",
    "onCommand:rgdEditor.openRgd",
    "onCommand:rgdEditor.openRgdText",
    "onCommand:rgdEditor.convertToText",
    "onCommand:rgdEditor.convertToBinary",
    "onCommand:rgdEditor.showInfo",
    "onCommand:rgdEditor.extractFromSga",
    "onCommand:rgdEditor.dumpToLua",
    "onCommand:rgdEditor.compileToRgd",
    "onCommand:rgdEditor.batchToLua",
    "onCommand:rgdEditor.batchToRgd",
    "onCommand:rgdEditor.selectLocaleFolder",
    "onCommand:rgdEditor.refreshTree",
    "onCommand:rgdEditor.loadTreeView",
    "onLanguage:rgd-text",
    "onCommand:rgd.fromLua",
    "onCommand:rgd.toLua",
    "onCommand:rgd.info",
    "onCommand:rgd.validate",
    "onCommand:rgdSuite.checkParity",
    "onCommand:rgdSuite.batchCheckParity"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "rgdEditor.rgdEditor",
        "displayName": "RGD Table Editor",
        "selector": [
          {
            "filenamePattern": "*.rgd"
          }
        ],
        "priority": "default"
      }
    ],
    "languages": [
      {
        "id": "rgd-text",
        "aliases": [
          "RGD Text",
          "rgd-text"
        ],
        "extensions": [
          ".rgd.txt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rgd-text",
        "scopeName": "source.rgd",
        "path": "./syntaxes/rgd.tmLanguage.json"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "rgdTree",
          "name": "RGD Tree",
          "when": "resourceExtname == .rgd || resourceExtname == .txt && resourceFilename =~ /\\.rgd\\.txt$/",
          "icon": "$(database)"
        }
      ]
    },
    "commands": [
      {
        "command": "rgdEditor.openRgd",
        "title": "Open (Table Editor)",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.openRgdText",
        "title": "Open (Plain Text Editor)",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.convertToText",
        "title": "Convert to Text Format",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.convertToBinary",
        "title": "Convert Text to Binary",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.showInfo",
        "title": "Show File Info",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.extractFromSga",
        "title": "Extract from SGA Archive",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.dumpToLua",
        "title": "Dump to Lua",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.compileToRgd",
        "title": "Compile Lua to RGD",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.editValue",
        "title": "Edit Value",
        "category": "RGD Suite",
        "icon": "$(edit)"
      },
      {
        "command": "rgdEditor.batchToLua",
        "title": "Batch Convert Folder to Lua",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.batchToRgd",
        "title": "Batch Compile Folder to RGD",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.selectLocaleFolder",
        "title": "Select Locale Folder",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.refreshTree",
        "title": "Refresh Tree View",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.revealNode",
        "title": "Reveal Node",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.loadTreeView",
        "title": "Load Tree View",
        "category": "RGD Suite"
      },
      {
        "command": "rgd.fromLua",
        "title": "Convert Lua to RGD (CLI)",
        "category": "RGD Suite"
      },
      {
        "command": "rgd.toLua",
        "title": "Convert RGD to Lua (CLI)",
        "category": "RGD Suite"
      },
      {
        "command": "rgd.info",
        "title": "Show RGD Info (CLI)",
        "category": "RGD Suite"
      },
      {
        "command": "rgd.validate",
        "title": "Validate File (CLI)",
        "category": "RGD Suite"
      },
      {
        "command": "rgdSuite.checkParity",
        "title": "Check Parity (RGD ↔ Lua)",
        "category": "RGD Suite"
      },
      {
        "command": "rgdSuite.batchCheckParity",
        "title": "Batch Parity Check (Folder)",
        "category": "RGD Suite"
      },
      {
        "command": "rgdEditor.openPowerShellSetup",
        "title": "Open PowerShell Terminal with CLI",
        "category": "RGD Suite"
      }
    ],
    "submenus": [
      {
        "id": "rgdSuite.explorerContext",
        "label": "RGD Suite",
        "icon": "$(database)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "rgdSuite.explorerContext",
          "group": "2_workspace@99",
          "when": "resourceExtname == .rgd || resourceExtname == .lua || resourceExtname == .sga || resourceFilename =~ /\\.rgd\\.txt$/ || explorerResourceIsFolder"
        }
      ],
      "rgdSuite.explorerContext": [
        {
          "when": "resourceExtname == .rgd",
          "command": "rgdEditor.openRgd",
          "group": "open@1"
        },
        {
          "when": "resourceExtname == .rgd",
          "command": "rgdEditor.openRgdText",
          "group": "open@2"
        },
        {
          "when": "resourceExtname == .rgd || resourceExtname == .lua",
          "command": "rgdSuite.checkParity",
          "group": "convert@1"
        },
        {
          "when": "resourceExtname == .rgd",
          "command": "rgdEditor.convertToText",
          "group": "convert@2"
        },
        {
          "when": "resourceFilename =~ /\\.rgd\\.txt$/",
          "command": "rgdEditor.convertToBinary",
          "group": "convert@3"
        },
        {
          "when": "resourceExtname == .rgd",
          "command": "rgdEditor.dumpToLua",
          "group": "convert@4"
        },
        {
          "when": "resourceExtname == .lua",
          "command": "rgdEditor.compileToRgd",
          "group": "convert@5"
        },
        {
          "when": "resourceExtname == .lua",
          "command": "rgd.fromLua",
          "group": "cli@1"
        },
        {
          "when": "resourceExtname == .rgd",
          "command": "rgd.toLua",
          "group": "cli@2"
        },
        {
          "when": "resourceExtname == .rgd",
          "command": "rgd.info",
          "group": "cli@3"
        },
        {
          "when": "resourceExtname == .rgd",
          "command": "rgd.validate",
          "group": "cli@4"
        },
        {
          "when": "resourceExtname == .rgd",
          "command": "rgdEditor.showInfo",
          "group": "info@1"
        },
        {
          "when": "resourceExtname == .sga",
          "command": "rgdEditor.extractFromSga",
          "group": "info@2"
        },
        {
          "when": "explorerResourceIsFolder",
          "command": "rgdEditor.batchToLua",
          "group": "batch@1"
        },
        {
          "when": "explorerResourceIsFolder",
          "command": "rgdEditor.batchToRgd",
          "group": "batch@2"
        },
        {
          "when": "explorerResourceIsFolder",
          "command": "rgdSuite.batchCheckParity",
          "group": "batch@3"
        },
        {
          "when": "resourceExtname == .rgd || resourceExtname == .lua || explorerResourceIsFolder",
          "command": "rgdEditor.selectLocaleFolder",
          "group": "config@1"
        }
      ],
      "view/item/context": [
        {
          "when": "view == rgdTree && viewItem == rgdValue",
          "command": "rgdEditor.editValue",
          "group": "inline"
        },
        {
          "when": "view == rgdTree",
          "command": "rgdEditor.revealNode",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "RGD Suite",
      "properties": {
        "rgdEditor.dictionaryPaths": {
          "type": "array",
          "default": [],
          "description": "Paths to additional hash dictionary files (.dic or .txt)"
        },
        "rgdEditor.autoConvertOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically convert text format back to binary on save"
        },
        "rgdEditor.defaultRgdVersion": {
          "type": "number",
          "default": 1,
          "enum": [1, 3],
          "description": "Default RGD version when creating new files"
        },
        "rgdEditor.preferredLanguage": {
          "type": "string",
          "default": "Chinese",
          "enum": [
            "English",
            "Chinese",
            "SChinese",
            "Japanese",
            "German",
            "French",
            "Spanish",
            "Italian",
            "Russian",
            "Korean",
            "Polish"
          ],
          "description": "Preferred language for UCS string resolution"
        },
        "rgdSuite.attribPath": {
          "type": "string",
          "default": "",
          "description": "Path to attrib folder for resolving references (auto-detected if empty)"
        },
        "rgdSuite.parityWorkers": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Worker threads used by Batch Parity Check. 0 = auto (logical CPU count − 1, minimum 1). Raise for faster throughput on many-core machines; lower if VS Code becomes unresponsive during large batches."
        },
        "rgdSuite.batchWorkers": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Worker threads used by Batch Convert Folder to Lua/RGD. 0 = auto (logical CPU count − 1, minimum 1). Raise for faster throughput on many-core machines; lower if VS Code becomes unresponsive during large batches."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node16 --minify --legal-comments=none --resolve-extensions=.ts,.js --tsconfig=tsconfig.json",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node16 --sourcemap --resolve-extensions=.ts,.js --tsconfig=tsconfig.json --watch",
    "package": "vsce package --no-dependencies && node -e \"const {execSync,version}=require('child_process'),p=require('./package.json');const src='rgd-suite-'+p.version+'.vsix';require('fs').copyFileSync(src,'rgd-suite-latest.vsix');console.log('Copied '+src+' -> rgd-suite-latest.vsix')\"",
    "build-all": "npm run build && npm run package",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.0.0",
    "esbuild": "^0.19.12",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@exodus/bytes": "^1.8.0"
  }
}
